generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Jewelry {
  id            Int       @id @default(autoincrement())
  name          String
  material      String
  color         String
  purchaseDate  DateTime
  storageLocation String
  suitableScenarios String
  imageUrl      String?
  purchasePrice Float?
  invoiceNumber String?
  createdAt     DateTime  @default(now())
  outfits       Outfit[]
  maintenances  Maintenance[]
  repairs       Repair[]
  lendings      Lending[]
  wearPlanItems WearPlanItem[]
  valuations    Valuation[]
  insurances    Insurance[]
  credentials   Credential[]
}

model Outfit {
  id           Int      @id @default(autoincrement())
  jewelryId    Int
  wearDate     DateTime
  outfitTags   String
  isAllergic   Boolean  @default(false)
  isFading     Boolean  @default(false)
  cleanStatus  String
  notes        String?
  createdAt    DateTime @default(now())
  jewelry      Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model Maintenance {
  id           Int      @id @default(autoincrement())
  jewelryId    Int
  date         DateTime
  type         String
  description  String
  result       String?
  createdAt    DateTime @default(now())
  jewelry      Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model Repair {
  id            Int      @id @default(autoincrement())
  jewelryId     Int
  problemType   String
  sendDate      DateTime
  repairItems   String
  cost          Float
  returnDate    DateTime?
  status        String
  notes         String?
  createdAt     DateTime @default(now())
  jewelry       Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model Lending {
  id                    Int      @id @default(autoincrement())
  jewelryId             Int
  borrowerName          String
  borrowerContact       String
  lendDate              DateTime
  expectedReturnDate    DateTime
  purpose               String
  deposit               Float    @default(0)
  conditionBeforeLend   String
  returnCondition       String?
  hasWear               Boolean  @default(false)
  compensationAmount    Float    @default(0)
  status                String   @default("借出中")
  actualReturnDate      DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  jewelry               Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model WearPlan {
  id                    Int       @id @default(autoincrement())
  planDate              DateTime
  scenario              String
  outfitTags            String
  candidateJewelryIds   String
  selectedJewelryIds    String?
  priority              Int       @default(1)
  forbiddenConditions   String?
  status                String    @default("待确认")
  confirmedAt           DateTime?
  conflictResolved      Boolean   @default(false)
  recommendationSnapshot String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  wearPlanItems         WearPlanItem[]
}

model WearPlanItem {
  id                    Int       @id @default(autoincrement())
  wearPlanId            Int
  jewelryId             Int
  recommendationScore   Int
  riskLevel             String
  riskLevelText         String
  riskScore             Int
  unavailableReasons    String?
  isAvailable           Boolean
  isSelected            Boolean   @default(false)
  factors               String?
  createdAt             DateTime  @default(now())
  wearPlan              WearPlan  @relation(fields: [wearPlanId], references: [id], onDelete: Cascade)
  jewelry               Jewelry   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([wearPlanId, jewelryId])
}

model Valuation {
  id              Int      @id @default(autoincrement())
  jewelryId       Int
  currentValue    Float
  valuationDate   DateTime
  valuationAgency String
  notes           String?
  createdAt       DateTime @default(now())
  jewelry         Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model Insurance {
  id               Int      @id @default(autoincrement())
  jewelryId        Int
  policyNumber     String
  insuranceCompany String
  startDate        DateTime
  endDate          DateTime
  insuredAmount    Float
  deductible       Float    @default(0)
  claimsContact    String
  status           String   @default("生效中")
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  jewelry          Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}

model Credential {
  id               Int      @id @default(autoincrement())
  jewelryId        Int
  type             String
  credentialNumber String?
  description      String?
  fileUrl          String?
  issueDate        DateTime?
  issuedBy         String?
  createdAt        DateTime @default(now())
  jewelry          Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
}
